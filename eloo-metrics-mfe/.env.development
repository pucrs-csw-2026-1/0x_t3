# Modo demonstração: liga os dados mockados no dev standalone (`npm run dev`),
# permitindo ver o dashboard populado sem o Metrics Service (T2) no ar.
# Carregado só em mode "development" — o Vitest (mode "test") NÃO lê este arquivo,
# então os testes continuam batendo no contrato via MSW.
VITE_USE_MOCKS=true

# Backends consumidos via proxy do Vite (ADR-0003) quando VITE_USE_MOCKS=false.
METRICS_SERVICE_URL=http://localhost:8000
AUTH_SERVICE_URL=http://localhost:8080
